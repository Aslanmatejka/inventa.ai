# Product Builder - Environment Variables Template

# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: Anthropic API Configuration
# ============================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# ============================================
# AI Model Configuration
# ============================================
# Model is hard-locked to claude-opus-4-7 in Backend/config.py.
# Any value set here is IGNORED on purpose (field_validator override).
# AI_MODEL_NAME=claude-opus-4-7

# ============================================
# Optional: Server Configuration
# ============================================
# Port for the API server (default: 3001)
PORT=3001

# Node environment (development | production)
NODE_ENV=development

# ============================================
# Optional: CAD Configuration
# ============================================
# CAD engine (CadQuery only)
CAD_ENGINE=cadquery

# ============================================
# Enable verbose logging
DEBUG=false

# ============================================
# Optional: MySQL Database
# ============================================
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password_here
# DB_NAME=product_builder
# DB_CONNECTION_LIMIT=10
